{
  "name": "photoframemaker",
  "version": "1.0.0",
  "description": "Photo Frame Maker by DY",
  "scripts": {
    "build": "rm -rf www && node build.js",
    "db:create": "npx wrangler d1 create photoframemaker-blog",
    "db:migrate": "npx wrangler d1 execute photoframemaker-blog --file=./migrations/0001_init.sql",
    "db:migrate:local": "npx wrangler d1 execute photoframemaker-blog --local --file=./migrations/0001_init.sql",
    "dev": "npm run build && npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npm run build && npx cap run android"
  },
  "keywords": [],
  "author": "DY",
  "license": "ISC",
  "dependencies": {
    "@capacitor-community/media": "^9.0.2",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "cssnano": "^7.1.3",
    "html-minifier-terser": "^7.2.0",
    "postcss-cli": "^11.0.1",
    "terser": "^5.46.1",
    "typescript": "^5.9.3"
  }
}
